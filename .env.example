# Krita AI Plugin Web - Configuración

# ============================================================
# COMFYUI - Configuración de conexión
# ============================================================
# IMPORTANTE: El contenedor Docker debe poder conectar a ComfyUI

# Opción 1: Si ComfyUI está en tu máquina local (mismo Mac/Windows)
# Usa host.docker.internal para apuntar al host
# COMFYUI_HOST=host.docker.internal
# COMFYUI_PORT=8188

# Opción 2: Si ComfyUI está en otro servidor de tu red local
# Usa la IP directa
# COMFYUI_HOST=192.168.1.100
# COMFYUI_PORT=8188

# Opción 3: Si ComfyUI tiene dominio público con HTTPS
COMFYUI_HOST=comfyui.khlloreda.com
COMFYUI_PORT=443

# ¿Usar HTTPS? (true para conexión segura)
COMFYUI_SECURE=true

# ============================================================
# Puerto local de Krita AI Web
# ============================================================
KRITA_HTTP_PORT=3333

# ============================================================
# CONTENT_FILTER — CivitAI + filtro LLM (prompt antes de ComfyUI)
# ============================================================
# 0 = sin restricción global: moderación CivitAI amplia y puedes apagar el filtro LLM en Configuración
# 1 = PG/PG-13 en CivitAI; filtro LLM obligatorio antes de cada generación
# 2 = hasta R en CivitAI; filtro LLM obligatorio
# CONTENT_FILTER=0

# ============================================================
# OAuth Microsoft (Entra ID) — inicio de sesión multiusuario
# ============================================================
# Si defines CLIENT_ID, SECRET, TENANT y REDIRECT_URI, la app exige login
# (Microsoft y/o usuario local según ALLOW_LEGACY_LOGIN).
#
# En Azure: App registration → Authentication → Web → Redirect URI debe coincidir
# exactamente con OAUTH_REDIRECT_URI (ej. https://tu-dominio/api/auth/microsoft/callback).
# Certificados y secretos → nuevo client secret.
# Single-tenant: solo cuentas de tu directorio.
#
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
# OAUTH_REDIRECT_URI=https://localhost:3333/api/auth/microsoft/callback
# URL que el navegador usa para abrir la SPA tras el login (sin barra final recomendado)
# APP_PUBLIC_URL=http://localhost:3333
# Emails (minúsculas, separados por coma) que reciben rol admin al darse de alta;
# si la BD no tiene admins, el primer usuario que entre será admin.
# OAUTH_ADMIN_EMAILS=admin@empresa.com
# Con OAuth activo: false desactiva POST /api/auth/login (solo Microsoft)
# ALLOW_LEGACY_LOGIN=true
# true si la app se sirve solo por HTTPS (cookies Secure)
# COOKIE_SECURE=false
